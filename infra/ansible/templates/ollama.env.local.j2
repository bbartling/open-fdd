{# workspace/ollama.env.local — sourced by run_local.sh; systemd EnvironmentFile (KEY=value) #}
OFDD_AI_BACKEND={{ ollama_ai_backend | default('auto') }}
OFDD_OLLAMA_RAM_TIER={{ ollama_ram_tier | default('8gb') }}
OFDD_OLLAMA_GPU_MODE={{ ollama_gpu_mode | default('cpu') }}
{% set gpu = ollama_gpu_mode | default('cpu') %}
OFDD_OLLAMA_NUM_GPU={% if gpu == 'auto' %}-1{% elif gpu == 'gpu' %}99{% else %}0{% endif %}
OFDD_OLLAMA_MODEL={{ ollama_model_for_tier[ollama_ram_tier | default('8gb')] }}
OFDD_OLLAMA_BASE_URL={{ ollama_base_url | default('http://127.0.0.1:11434') }}
