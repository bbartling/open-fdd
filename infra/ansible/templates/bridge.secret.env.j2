{# Bridge secrets — mode 0600 on target; referenced by openfdd-bridge.service EnvironmentFile #}
{% if commission_agent_token | default('') | length > 0 %}
OPENFDD_BACNET_COMMISSION_TOKEN={{ commission_agent_token }}
{% endif %}
{% if ofdd_auth_secret | default('') | length > 0 %}
OFDD_AUTH_SECRET={{ ofdd_auth_secret }}
OFDD_WEB_USER={{ ofdd_web_user | default('operator') }}
OFDD_WEB_PASSWORD={{ ofdd_web_password }}
{% endif %}
