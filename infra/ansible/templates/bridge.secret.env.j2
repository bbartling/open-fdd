{# Bridge secrets — mode 0600 on target; referenced by openfdd-bridge.service EnvironmentFile #}
{# Values are double-quoted with \ and " escaped for systemd EnvironmentFile parsing. #}
{% macro env_quote(v) -%}"{{ (v | string) | replace('\\', '\\\\') | replace('"', '\\"') }}"{%- endmacro %}
{% if commission_agent_token | default('') | length > 0 %}
OPENFDD_BACNET_COMMISSION_TOKEN={{ env_quote(commission_agent_token) }}
{% endif %}
{% if ofdd_auth_secret | default('') | length > 0 %}
OFDD_AUTH_SECRET={{ env_quote(ofdd_auth_secret) }}
OFDD_WEB_USER={{ env_quote(ofdd_web_user | default('operator')) }}
OFDD_WEB_PASSWORD={{ env_quote(ofdd_web_password) }}
{% endif %}
