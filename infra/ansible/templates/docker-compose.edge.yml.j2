# Rendered on edge host by deploy_docker.yml — do not edit on VM by hand.
# Host Caddy (:80) → bridge on 127.0.0.1:{{ openfdd_bridge_port }}
{% macro ofdd_image(short_name) -%}
{%- if openfdd_docker_pull_from_ghcr | default(false) | bool -%}
{{ openfdd_docker_registry | default('ghcr.io') }}/{{ openfdd_docker_registry_org | default('bbartling') }}/{{ short_name }}:{{ openfdd_docker_image_tag }}
{%- else -%}
{{ short_name }}:{{ openfdd_docker_image_tag | default('local') }}
{%- endif -%}
{%- endmacro %}

name: openfdd-edge

services:
  bridge:
    image: {{ ofdd_image('openfdd-bridge') }}
    ports:
      - "127.0.0.1:{{ openfdd_bridge_port }}:8765"
    volumes:
      # Runtime state only — application code comes from the GHCR image (no workspace/api bind mount).
      - {{ openfdd_remote_dir }}/workspace:/var/openfdd/workspace
{% if openfdd_docker_bridge_secret | default(true) | bool %}
      - /etc/openfdd/bridge.secret.env:/etc/openfdd/bridge.secret.env:ro
{% endif %}
    environment:
      OPENFDD_BACNET_COMMISSION_URL: "{% if bacnet_commission_network_host | default(false) | bool %}http://host.docker.internal:8767{% else %}http://commission:8767{% endif %}"
      OFDD_ALLOW_LAN_INTERNAL_INGEST: "1"
{% if enable_mcp | default(true) | bool %}
      OFDD_MCP_REST_BASE: http://mcp-rag:{{ mcp_listen_port | default(8090) }}
      OFDD_MCP_ENABLED: "1"
{% else %}
      OFDD_MCP_ENABLED: "0"
{% endif %}
      OFDD_OLLAMA_ENABLED: "{% if enable_ollama | default(false) | bool %}1{% else %}0{% endif %}"
{% if enable_ollama | default(false) | bool %}
      OFDD_OLLAMA_BASE_URL: "{% if not (openfdd_docker_ollama | default(false) | bool) %}http://host.docker.internal:11434{% else %}http://ollama:11434{% endif %}"
{% endif %}
    env_file:
      - path: {{ openfdd_remote_dir }}/workspace/auth.env.local
        required: false
      - path: {{ openfdd_remote_dir }}/workspace/mcp.env.local
        required: false
      - path: {{ openfdd_remote_dir }}/workspace/ollama.env.local
        required: false
      - path: {{ openfdd_remote_dir }}/workspace/data.env.local
        required: false
      - path: {{ openfdd_remote_dir }}/workspace/json_api.env.local
        required: false
    depends_on:
      - commission
{% if enable_mcp | default(true) | bool %}
      - mcp-rag
{% endif %}
{% if (enable_ollama | default(false) | bool and not (openfdd_docker_ollama | default(true) | bool)) or (bacnet_commission_network_host | default(false) | bool) %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
    restart: unless-stopped

  commission:
    image: {{ ofdd_image('openfdd-commission') }}
{% if bacnet_commission_network_host | default(false) | bool %}
    network_mode: host
{% endif %}
    volumes:
      - {{ openfdd_remote_dir }}/workspace:/var/openfdd/workspace
    environment:
      OPENFDD_WORKSPACE_DIR: /var/openfdd/workspace
      OPENFDD_REPO_ROOT: /app
    restart: unless-stopped

{% if enable_mcp | default(true) | bool %}
  mcp-rag:
    image: {{ ofdd_image('openfdd-mcp-rag') }}
    volumes:
      - {{ openfdd_remote_dir }}/workspace:/var/openfdd/workspace
    restart: unless-stopped
{% endif %}

{% if enable_ollama | default(false) | bool and openfdd_docker_ollama | default(false) | bool %}
  ollama:
    image: ollama/ollama:{{ ollama_docker_image_tag | default('latest') }}
    ports:
      - "127.0.0.1:11434:11434"
    volumes:
      - {{ openfdd_remote_dir }}/docker/volumes/ollama:/root/.ollama
    restart: unless-stopped
{% if ollama_gpu_mode | default('cpu') in ['gpu', 'auto'] %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{% endif %}
{% endif %}
