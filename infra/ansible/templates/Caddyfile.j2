# Installed by Ansible when caddy_enabled — HTTP or self-signed TLS on OT LAN.
{% if caddy_mode | default('http') == 'tls' %}
:80 {
	redir https://{host}{uri} permanent
}

:443 {
	tls /etc/openfdd/caddy/cert.pem /etc/openfdd/caddy/key.pem

	# HSTS only — app headers from bridge SecurityHeadersMiddleware
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
	reverse_proxy 127.0.0.1:{{ openfdd_bridge_port }} {
		header_down -Server
	}
	header -Server
}
{% else %}
:80 {
	reverse_proxy 127.0.0.1:{{ openfdd_bridge_port }} {
		header_down -Server
	}
	header -Server
}
{% endif %}
