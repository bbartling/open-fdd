{# workspace/mcp.env.local — bridge reads OFDD_MCP_*; MCP sidecar listens on loopback #}
OFDD_MCP_ENABLED={{ '1' if (enable_mcp | default(true) | bool) else '0' }}
OFDD_MCP_REST_BASE=http://127.0.0.1:{{ mcp_listen_port | default(8090) }}
OFDD_MCP_LISTEN_HOST=127.0.0.1
OFDD_MCP_LISTEN_PORT={{ mcp_listen_port | default(8090) }}
OFDD_MCP_RAG_INDEX_PATH={{ openfdd_remote_dir }}/workspace/data/mcp/rag_index.json
