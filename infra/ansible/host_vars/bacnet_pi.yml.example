---
# Boss Pi test bench — MS/TP via BASRT-B router

site_id: demo
building_id: bens-office

bacnet_instance_id: 599999
bacnet_device_name: OpenFddPiBench
bacnet_bind_address: "127.0.0.1/24:47809"
# Opt-in to LAN BACnet bind only when intentional, e.g. bacnet_bind_address: "{{ ansible_host }}/24:47809"
bacnet_route_aware: true
bacnet_network: 1
bacnet_router_ip: 192.168.204.200
bacnet_mstp_net: 2000

enable_bacnet_poll_driver: false
bacnet_poll_interval: 60
