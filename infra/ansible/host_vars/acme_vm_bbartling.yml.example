---
# vm-bbartling — Acme real building (VAV/AHU/boiler on OT BACnet)
# Copy: cp host_vars/acme_vm_bbartling.yml.example host_vars/acme_vm_bbartling.yml
# Inventory host acme_vm_bbartling → Tailscale IP (SSH); BACnet bind is OT NIC below.

site_id: acme
building_id: vm-bbartling
# From: python3 scripts/gl36_site_model.py --site-id acme --building-id vm-bbartling
edge_model_json: acme_vm-bbartling_gl36_model.json
openfdd_docker_stack: true

# Pin to tag from GitHub Actions → Publish Docker addons (ghcr.io/bbartling/*)
openfdd_docker_pull_from_ghcr: true
openfdd_docker_image_tag: "latest"

# post_deploy_check.sh --limit acme_vm_bbartling --full
post_check_full: true
post_check_min_model_points: 300
post_check_min_bacnet_devices: 30
post_check_min_bacnet_points: 340
post_check_min_saved_rules: 1
post_check_min_bound_points: 10

# BACnet Device instance (Who-Is / bind). Change only if the OT network requires a fixed ID.
bacnet_instance_id: 3456791
bacnet_device_name: OpenFDD
# Dedicated OT NIC — not Tailscale
bacnet_bind_address: "10.200.200.185/24:47808"
bacnet_commission_network_host: true

bacnet_discover_low: 1
bacnet_discover_high: 4194303
bacnet_discover_timeout: 30

# GL36 poll set: JCI VAV 1–100, RTU 1100, boiler 1002, Trane VAV 11000–13000 (see acme_trim_devices.sh)
enable_bacnet_poll_driver: true
bacnet_poll_interval: 60

# No MCP on Acme edge — central portfolio MCP over Tailscale; Ollama off by default
enable_mcp: false
post_check_require_mcp: false
enable_ollama: false
ollama_required: false
ollama_ram_tier: "16gb"
openfdd_docker_ollama: false
# Optional: -e enable_ollama=true -e openfdd_docker_ollama=true for in-stack Ollama

# ~125 GiB feather cap ≈ 1 year at 1-min temp polling scale
feather_max_gib: 125
feather_retention_days: 365

# GL36 rules: push via API after deploy (setup_gl36_fdd.py --host --token), not Ansible copy
regenerate_gl36_rules_on_deploy: false
openfdd_push_site_pack: false
openfdd_push_bacnet_config: false
gl36_ahu_equipment_id: acme-vm-bbartling-rtu-01
gl36_fan_point_id: "1100-analog-output-1"

# Building agent check-in timer (poll/FDD/memory append every 6h — no FDD batch by default)
install_building_agent_timer: true
enable_building_agent_timer: true
building_agent_interval_hours: 6
building_agent_run_fdd_batch: false
building_agent_window_minutes: 60
