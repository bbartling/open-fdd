---
# vm-bbartling — Acme real building (VAV/AHU/boiler on OT BACnet)
# Copy: cp host_vars/acme_vm_bbartling.yml.example host_vars/acme_vm_bbartling.yml
# Inventory host acme_vm_bbartling → Tailscale IP (SSH); BACnet bind is OT NIC below.

site_id: acme
building_id: vm-bbartling
# From: python3 scripts/gl36_site_model.py --site-id acme --building-id vm-bbartling
edge_model_json: acme_vm-bbartling_gl36_model.json
openfdd_docker_stack: true

# Pin to tag from GitHub Actions → Publish Docker addons (ghcr.io/bbartling/*)
openfdd_docker_pull_from_ghcr: true
openfdd_docker_image_tag: "2026.06.04-edge"

# BACnet Device instance (Who-Is / bind). Change only if the OT network requires a fixed ID.
bacnet_instance_id: 3456791
bacnet_device_name: OpenFDD
# Dedicated OT NIC — not Tailscale
bacnet_bind_address: "10.200.200.185/24:47808"
bacnet_commission_network_host: true

bacnet_discover_low: 1
bacnet_discover_high: 4194303
bacnet_discover_timeout: 30

# Poll via commission agent on host network (do not also enable bacnet-poll — double BACnet bind).
enable_bacnet_poll_driver: false
bacnet_poll_interval: 60

# 4c / 16GB VM — local Ollama qwen3:4b + MCP RAG
enable_mcp: true
enable_ollama: true
ollama_required: true
ollama_ram_tier: "16gb"
# In-stack Ollama container (set false when deploying with -e openfdd_docker_ollama=false)
openfdd_docker_ollama: true
# Post-deploy requires reachable Ollama only when in-stack Ollama is enabled (see post_deploy_check.sh)
# post_check_require_ollama: true

# ~125 GiB feather cap ≈ 1 year at 1-min temp polling scale
feather_max_gib: 125
feather_retention_days: 365
