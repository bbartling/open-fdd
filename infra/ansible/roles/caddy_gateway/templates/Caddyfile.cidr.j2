:80 {
	encode zstd gzip

	@lan remote_ip {{ lan_cidr_allowlist }}
	handle @lan {
		basicauth * {
			{{ caddy_basic_auth_user }} {{ caddy_basic_auth_hash }}
		}

		handle_path /api/openfdd/* {
			reverse_proxy 127.0.0.1:{{ openfdd_bridge_port }}
		}

		handle_path /api/mcp/* {
			reverse_proxy 127.0.0.1:{{ openfdd_mcp_port }}
		}

		handle_path /api/easyaso/* {
			reverse_proxy 127.0.0.1:{{ easyaso_supervisor_port }}
		}

		handle_path /api/diy/* {
			reverse_proxy 127.0.0.1:{{ diy_bacnet_port }}
		}

		reverse_proxy 127.0.0.1:{{ openfdd_ui_port }}
	}

	respond "forbidden: source IP not allowed" 403
}
