# Copy to acme.env.local and fill in real values (chmod 600).
# Loaded automatically by infra/ansible/deploy.sh when using:
#   ./deploy.sh <component> --limit acme_vm_bbartling

# --- SSH (Tailscale or LAN — matches inventory.yml ansible_host) ---
export SSHPASS='REPLACE_WITH_VM_SSH_PASSWORD'
export ACME_SSH_HOST='198.51.100.55'
export ACME_SSH_USER='bbartling'

# Ansible inventory host name (not DNS hostname)
export ACME_ANSIBLE_LIMIT='acme_vm_bbartling'

# --- Site / building (commissioning + feather paths) ---
export ACME_SITE_ID='acme'
export ACME_BUILDING_ID='vm-bbartling'

# --- BACnet OT NIC (dedicated interface — not Tailscale) ---
export ACME_BACNET_BIND='10.0.200.185/24:47808'
export ACME_BACNET_INSTANCE='3456791'
export ACME_BACNET_DEVICE_NAME='OpenFDD'

# --- Operator UI (Caddy on edge — adjust if TLS or different host) ---
export ACME_DASHBOARD_URL='http://198.51.100.55/'
# Integrator login: workspace/auth.env.local on control machine (synced separately via deploy config tag)

# --- Edge paths on VM ---
export ACME_REMOTE_REPO='/home/bbartling/open-fdd'
export ACME_EDGE_BACKUP='edge_backup/local/acme/vm-bbartling'
