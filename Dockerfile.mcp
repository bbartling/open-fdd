# Slim Rust MCP image — stdio entrypoint only; talks to central over OPENFDD_API_BASE.
# Run: docker run -i ghcr.io/bbartling/openfdd-mcp:<tag>
FROM rust:1.95-bookworm AS builder
WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY vendor ./vendor
COPY edge ./edge
COPY mcp ./mcp
COPY crates ./crates
# Workspace members include services/* — cargo metadata fails without these paths.
COPY services ./services
RUN cargo build --release -p openfdd-mcp

FROM debian:bookworm-slim AS runtime
ARG OPENFDD_IMAGE_TAG=dev
ARG OPENFDD_BUILD_GIT_SHA=unknown
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/* \
  && useradd --create-home --uid 10002 --shell /usr/sbin/nologin openfdd-mcp
COPY --from=builder /app/target/release/openfdd-mcp /usr/local/bin/openfdd-mcp
ENV OPENFDD_IMAGE_TAG=${OPENFDD_IMAGE_TAG} \
    OPENFDD_GIT_SHA=${OPENFDD_BUILD_GIT_SHA} \
    OPENFDD_API_BASE=http://central:8080
USER openfdd-mcp
ENTRYPOINT ["openfdd-mcp"]
