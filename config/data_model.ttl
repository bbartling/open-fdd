ofdd:platform_config a ofdd:PlatformConfig ;
    ofdd:bacnetEnabled true ;
    ofdd:bacnetGateways "" ;
    ofdd:bacnetScrapeIntervalMin 1 ;
    ofdd:bacnetServerUrl "http://localhost:8080" ;
    ofdd:bacnetSiteId "default" ;
    ofdd:brickTtlDir "config" ;
    ofdd:graphSyncIntervalMin 5 ;
    ofdd:lookbackDays 3 ;
    ofdd:openMeteoDaysBack 3 ;
    ofdd:openMeteoEnabled true ;
    ofdd:openMeteoIntervalHours 24 ;
    ofdd:openMeteoLatitude 41.0 ;
    ofdd:openMeteoLongitude -87.0 ;
    ofdd:openMeteoSiteId "asdf" ;
    ofdd:openMeteoTimezone "America/Chicago" ;
    ofdd:ruleIntervalHours 0.0 ;
    ofdd:rulesDir "stack/rules" .

