    ofdd:openMeteoDaysBack 3 ;
    ofdd:openMeteoEnabled true ;
    ofdd:openMeteoIntervalHours 24 ;
    ofdd:openMeteoLatitude 41.0 ;
    ofdd:openMeteoLongitude -87.0 ;
    ofdd:openMeteoSiteId "TestBenchSite" ;
    ofdd:openMeteoTimezone "America/Chicago" ;
    ofdd:ruleIntervalHours 0.0 ;
    ofdd:rulesDir "analyst/rules" .

