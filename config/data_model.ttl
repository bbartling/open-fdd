ofdd:platform_config a ofdd:PlatformConfig ;
    ofdd:bacnetEnabled true ;
    ofdd:bacnetGateways "" ;
    ofdd:bacnetScrapeIntervalMin 1 ;
    ofdd:bacnetServerUrl "http://localhost:8080" ;
    ofdd:bacnetSiteId "default" ;
