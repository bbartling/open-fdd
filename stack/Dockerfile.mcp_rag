FROM python:3.11-slim

WORKDIR /app

COPY pyproject.toml README.md /app/
COPY open_fdd /app/open_fdd
COPY scripts /app/scripts
COPY docs /app/docs
COPY pdf /app/pdf
COPY stack /app/stack

RUN pip install --no-cache-dir -e ".[platform]"

EXPOSE 8090

CMD ["python", "-m", "uvicorn", "open_fdd.platform.mcp_rag.app:app", "--host", "0.0.0.0", "--port", "8090"]

