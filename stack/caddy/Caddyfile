# Open-FDD reverse proxy (dev: no auth; add basic_auth for production — see docs/security.md).
# Port 80 → frontend; /ai/* and common API paths → API so Overview AI and similar work when using Caddy as entry.

:80 {
	handle /ai* {
		reverse_proxy api:8000
	}
	handle /api* {
		uri strip_prefix /api
		reverse_proxy api:8000
	}
	handle /auth* {
		reverse_proxy api:8000
	}
	handle /ws* {
		reverse_proxy api:8000
	}
	handle /* {
		reverse_proxy frontend:5173
	}
}
