# Open-FDD Rust Edge local environment
# Copy this file to .env and edit as needed.

OPENFDD_JWT_SECRET=dev-change-me-openfdd-rust-edge
OPENFDD_WORKSPACE=/app/workspace

# BACnet mode:
# - simulated: safe CI/dev mode, no OT network required
# - live: use host OT NIC and live BACnet adapter path
OPENFDD_BACNET_MODE=simulated

# Linux OT LAN default observed on bensbench:
# ip a showed enp3s0 = 192.168.204.55/24
OPENFDD_BACNET_IFACE=enp3s0
OPENFDD_BACNET_BIND=192.168.204.55/24:47808
OPENFDD_BACNET_DEVICE_INSTANCE=599999
OPENFDD_BACNET_DEVICE_NAME=OpenFDD
OPENFDD_BACNET_SCAN_INTERVAL_SECONDS=3600
OPENFDD_BACNET_POLL_INTERVAL_SECONDS=60

# Set to 1 only when you intentionally want the helper script to try adding
# OPENFDD_BACNET_STATIC_CIDR to OPENFDD_BACNET_IFACE with sudo.
OPENFDD_BACNET_CONFIGURE_NIC=0
OPENFDD_BACNET_STATIC_CIDR=192.168.204.55/24
