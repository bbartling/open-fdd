PREFIX brick: <https://brickschema.org/schema/Brick#>
PREFIX ref: <https://brickschema.org/schema/Brick/ref#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?site ?site_label ?equipment ?equipment_type ?point ?point_type WHERE {
  ?site a brick:Site .
  OPTIONAL { ?site rdfs:label ?site_label }

  OPTIONAL {
    ?equipment brick:isPartOf|brick:hasPart ?site .
    ?equipment a ?equipment_type .
    FILTER (?equipment_type IN (
      brick:AHU,
      brick:VAV,
      brick:Boiler,
      brick:Chiller,
      brick:Cooling_Tower,
      brick:Pump,
      brick:Fan,
      brick:Heat_Exchanger,
      brick:Meter
    ))

    OPTIONAL {
      ?equipment brick:hasPoint ?point .
      ?point a ?point_type .
      FILTER (?point_type IN (
        brick:Outside_Air_Temperature_Sensor,
        brick:Outdoor_Air_Temperature_Sensor,
        brick:Supply_Air_Temperature_Sensor,
        brick:Discharge_Air_Temperature_Sensor,
        brick:Zone_Air_Temperature_Sensor,
        brick:Heating_Command,
        brick:Cooling_Command,
        brick:Heating_Enable_Command,
        brick:Cooling_Enable_Command,
        brick:Supply_Air_Flow_Sensor,
        brick:Discharge_Air_Flow_Sensor,
        brick:Valve_Command,
        brick:Damper_Command,
        brick:Fan_Status,
        brick:Pump_Status
      ))
    }
  }
}
ORDER BY ?site_label ?equipment ?point
