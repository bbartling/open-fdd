# Recipe 3: Point labels for TestBenchSite (test bench default)
# Run via POST /data-model/sparql or Data Model page → Run SPARQL
PREFIX brick: <https://brickschema.org/schema/Brick#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?pt_label WHERE {
  ?pt brick:isPointOf ?eq .
  ?eq brick:isPartOf ?site .
  ?site rdfs:label "TestBenchSite" .
  ?pt rdfs:label ?pt_label .
}
