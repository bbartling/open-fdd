[Unit]
Description=easy-aso Supervisor (JSON-RPC)
After=network-online.target diy-bacnet-server.service
Wants=network-online.target

[Service]
Type=simple
User=openfdd
Group=openfdd
WorkingDirectory=/opt/easy-aso
EnvironmentFile=/etc/openfdd/bench.env
ExecStart=/opt/easy-aso/.venv/bin/easy-aso-supervisor --host ${SUPERVISOR_HOST} --port ${SUPERVISOR_PORT}
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
