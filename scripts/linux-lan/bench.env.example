# Copy to /etc/openfdd/bench.env and replace placeholders.
# chmod 600 /etc/openfdd/bench.env

# ---------- Open-FDD ----------
OFDD_DESKTOP_DATA_DIR=/opt/open-fdd/stack/local-data
OFDD_MODEL_TTL_PATH=/opt/open-fdd/stack/local-data/data_model.ttl
OFDD_MODEL_TTL_MIRROR_PATH=/opt/open-fdd/stack/local-data/data_model.mirror.ttl
OFDD_TTL_SYNC_INTERVAL_SECONDS=5

# Keep backend private; Caddy is ingress.
OFDD_BRIDGE_HOST=127.0.0.1
OFDD_BRIDGE_PORT=8765
OFDD_BRIDGE_URL=http://127.0.0.1:8765
OFDD_UI_PUBLIC_BASE=http://127.0.0.1

# MCP
OFDD_MCP_LISTEN_HOST=127.0.0.1
OFDD_MCP_LISTEN_PORT=8090
OFDD_MCP_REST_BASE=http://127.0.0.1:8090
OFDD_MCP_OFDD_API_URL=http://127.0.0.1:8765
OFDD_MCP_ENABLE_ACTION_TOOLS=1
OFDD_MCP_OFDD_API_KEY=replace-with-random-long-token

# Open-FDD BACnet pull -> DIY RPC auth
OFDD_BACNET_SERVER_API_KEY=replace-with-random-long-token

# ---------- easy-aso ----------
SUPERVISOR_HOST=127.0.0.1
SUPERVISOR_PORT=18090
SUPERVISOR_DB_PATH=/opt/easy-aso/data/supervisor.sqlite
SUPERVISOR_API_KEY=replace-with-random-long-token

SUPERVISOR_BACNET_RPC_URL=http://127.0.0.1:8080
SUPERVISOR_BACNET_RPC_ENTRYPOINT=/api
SUPERVISOR_BACNET_RPC_BEARER=${OFDD_BACNET_SERVER_API_KEY}

# ---------- DIY BACnet ----------
BACNET_RPC_API_KEY=replace-with-random-long-token

# ---------- UI ----------
# Same-origin API via Caddy path routes.
VITE_DESKTOP_BRIDGE_BASE=/api/openfdd
