# Bench overrides for scripts/bench_test.sh (copy to scripts/bench.env.local).
# These are test-driver parameters — NOT docker-compose sidecar startup config.
#
# Modbus host/port/unit are sent in POST /modbus/read JSON bodies.
# BACnet device/point IDs are sent in POST /bacnet/* JSON bodies.
# Haystack URL/credentials must match what the sidecar was started with (HAYSTACK_* in .env).

BENCH_BASE=http://127.0.0.1:8080
OPENFDD_FIELDBUS_API_KEY=bench-demo-key-1234567890

# BACnet bench device (MSTP router → 192.168.204.200)
BENCH_BACNET_DEVICE=5007
BENCH_BACNET_READ_TYPE=analog-input
BENCH_BACNET_READ_INST=1173
BENCH_BACNET_OVR_TYPE=analog-output
BENCH_BACNET_OVR_INST=2466
BENCH_BACNET_EXPECT_PRIORITY=8
BENCH_BACNET_EXPECT_VALUE=55

# Modbus test bench (open-fdd site.local.toml)
BENCH_MODBUS_HOST=192.168.204.14
BENCH_MODBUS_PORT=1502
BENCH_MODBUS_UNIT=1
BENCH_MODBUS_REG=0
BENCH_MODBUS_FN=input

# Haystack Niagara (verify sidecar .env matches)
BENCH_HAYSTACK_URL=https://192.168.204.11/haystack
BENCH_HAYSTACK_USER=open_fdd
BENCH_HAYSTACK_FILTER=point and temp

# Half-hour soak (0 = single pass)
# BENCH_MINUTES=30
# BENCH_INTERVAL_SECS=60
