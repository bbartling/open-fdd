# Bench overrides for scripts/fieldbus/bench_test.sh
# (copy to scripts/fieldbus/bench.env.local — gitignored locally).
#
# Do NOT put private OT LAN addresses in-repo; supply them via local env files.

BENCH_BASE=http://127.0.0.1:8080
OPENFDD_FIELDBUS_API_KEY=bench-demo-key-1234567890

# BACnet device under test (override from your local lab)
BENCH_BACNET_DEVICE=599999
BENCH_BACNET_READ_TYPE=analog-input
BENCH_BACNET_READ_INST=1
BENCH_BACNET_OVR_TYPE=analog-value
BENCH_BACNET_OVR_INST=1
BENCH_BACNET_EXPECT_PRIORITY=8
BENCH_BACNET_EXPECT_VALUE=55

# Modbus (POST /modbus/read JSON body)
BENCH_MODBUS_HOST=127.0.0.1
BENCH_MODBUS_PORT=1502
BENCH_MODBUS_UNIT=1
BENCH_MODBUS_REG=0
BENCH_MODBUS_FN=input

# Haystack (must match sidecar HAYSTACK_* env)
BENCH_HAYSTACK_URL=http://127.0.0.1:8081
BENCH_HAYSTACK_USER=open_fdd
BENCH_HAYSTACK_FILTER=point and temp
