# Copy to `.env` and set paths for your machine (Windows or Linux).
# Relative paths resolve from vibe_code_apps_19/ (repo app root).
#
# Step 1 — CSV tree: junction/symlink ./data/hvac_systems_CLEANED to your imports folder,
#   or set an absolute path below.
# Step 2 — Data model: open /data_model.html → bootstrap / AI import / export
# Step 3 — Validate: Advanced tab → Validate all SPARQL presets
# Step 4 — FDD + analytics use the synced RDF model (no hardcoded CSV paths)

# Central API (compose sets OPENFDD_API_BASE=http://central:8080)
# OPENFDD_API_BASE=http://127.0.0.1:8080
#
# When central has OPENFDD_JWT_SECRET, give the UI a Bearer:
# OPENFDD_API_TOKEN=...          # preferred (pre-minted JWT)
# OPENFDD_ADMIN_PASSWORD=...     # or login as admin (also OPENFDD_UI_USERNAME)
# OPENFDD_UI_USERNAME=admin
# OPENFDD_UI_PASSWORD=...
#
# Emergency only — agent/export pandas FDD (default is SQL-only):
# OPENFDD_ALLOW_PANDAS_FDD=1

# Relative path (works when data/hvac_systems_CLEANED is symlinked to your CSV tree)
HVAC_DATA_ROOT=./data/hvac_systems_CLEANED
HVAC_BUILDING=BUILDING_100

# Windows absolute example:
# HVAC_DATA_ROOT=C:/Users/you/path/to/hvac_systems_CLEANED

# Linux absolute example:
# HVAC_DATA_ROOT=/home/you/hvac_systems_CLEANED

HVAC_WEATHER_SUBDIR=weather
HVAC_TIMEZONE=America/Chicago

# Optional: override generated RDF store location (default data/rdf/)
# HAYSTACK_RDF_ROOT=./data/rdf

# Dashboard mode (full = local analyst, api = JSON-only headless, deploy = read-only site/)
# DASHBOARD_MODE=full
DASHBOARD_MODE=full

# Engineer PIN for tuning locked packages (default: vibe-coder)
ENGINEER_PIN=change-me
FLASK_SECRET_KEY=change-me
