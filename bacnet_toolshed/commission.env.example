# Copy to workspace/bacnet/commissioning/commission.env (gitignored under workspace/)
# BACpypes3 must bind the host NIC IP (not 127.0.0.1) for LAN Who-Is — see scripts/bacnet_whois_smoke.sh
SITE_ID=demo
BUILDING_ID=plant1
BACNET_BIND=192.168.1.50/24:47808
BACNET_NAME=OpenFddEdge
BACNET_INSTANCE=599999
DISCOVER_LOW=1
DISCOVER_HIGH=4194303
# MS/TP via IP router (optional):
# ROUTER_IP=192.168.1.1
# MSTP_NET=2000
# BACNET_NETWORK=1
DISCOVER_TIMEOUT=20
