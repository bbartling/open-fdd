# Optional override: copy to workspace/data.env.local (gitignored).
#
# Bootstrap (run_local.sh, feather-maintain):
#   • data.env.local exists  → source it (your settings win)
#   • no .local file         → defaults below (same as this example)
#
# One-off maintenance without run_local.sh:
#   set -a && source workspace/data.env.local && set +a
#   python -m openfdd_bridge.feather_store --maintain

# Max feather store size (GiB). 0 = no cap (time-based prune only).
OFDD_FEATHER_MAX_GIB=5

# Drop rows older than N days on --maintain / daily timer.
OFDD_FEATHER_RETENTION_DAYS=90

# Oldest time window removed per trim pass when over the GiB cap.
OFDD_FEATHER_TRIM_CHUNK_HOURS=24

# BACnet driver registry: enabled by default for integrator commissioning on edge stacks.
# Read-only monitor sites can disable Add device:
# OFDD_DISABLE_BACNET_DISCOVERY_MUTATIONS=1

# --- Audit / error / stdout log retention (bridge) ---
# Structured JSONL under workspace/logs/; rotation runs at startup + every N hours.
# OFDD_LOG_RETENTION_DAYS=90          # drop audit/error lines older than N days
# OFDD_LOG_MAX_MB=50                  # rotate audit.jsonl / error.jsonl when larger
# OFDD_LOCAL_RUN_LOG_MAX_MB=25        # rotate workspace/.local-run/*.log (run_local.sh)
# OFDD_LOG_ROTATE_INTERVAL_HOURS=6    # background retention pass while bridge is up
# OFDD_AUDIT_LOG_PATH=                # optional override (default workspace/logs/audit.jsonl)
# OFDD_ERROR_LOG_PATH=                # optional override (default workspace/logs/error.jsonl)
