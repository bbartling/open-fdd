# Open-FDD — HTTP entry on :80 (no port in the browser URL).
# Bridge binds 127.0.0.1:8765; Caddy is the only LAN-facing listener.
# Security headers (CSP, X-Frame-Options, COOP, CORP, …) are set by the bridge
# SecurityHeadersMiddleware — do not duplicate them here.

:80 {
	reverse_proxy 127.0.0.1:8765 {
		header_down -Server
	}
	header -Server
}
