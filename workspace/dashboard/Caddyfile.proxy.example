# Same-origin production ingress: static UI + reverse proxy to central API.
# Replace Caddyfile.ui in the UI image, or run as a standalone ingress container.
#
# Compose service names (standalone / central stacks):
#   ui      — this Caddy (static files in /srv)
#   central — openfdd-central on :8080
#
# Build UI with empty VITE_API_BASE so the browser uses same-origin /api/*.

:80 {
  encode gzip

  handle /api/* {
    reverse_proxy central:8080
  }

  handle /docs* {
    reverse_proxy central:8080
  }

  handle /openapi.json {
    reverse_proxy central:8080
  }

  handle /health {
    reverse_proxy central:8080
  }

  root * /srv
  try_files {path} /index.html
  file_server

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy no-referrer
  }
}
