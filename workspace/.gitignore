# Runtime artifacts under workspace (starter trees tracked via negation)
*
!.gitignore
!*.env.example
!pentest.env.example
!api/
!api/**
!mcp_rag/
!mcp_rag/**
!mcp_server/
!mcp_server/**
!cloud_exporter/
!cloud_exporter/**
!MEMORY.md.example
!memory/
!memory/**
**/mcp_server/**/__pycache__/
**/mcp_server/**/*.py[cod]
**/mcp_rag/**/__pycache__/
**/mcp_rag/**/*.py[cod]
**/api/**/__pycache__/
**/api/**/*.py[cod]
**/cloud_exporter/**/__pycache__/
**/cloud_exporter/**/*.py[cod]
!dashboard/
!dashboard/**
!data/
!data/**
# Runtime state (bridge / FDD loop — never commit; Docker may write as root)
data/data_model.ttl
data/model.json
data/fdd_results.json
data/rules_store.json
data/runtime_metrics.json
data/building_alerts.json
data/feather_store/
data/**/*.feather
data/playground/draft_rules.json
!deploy/
!deploy/**
!scripts/
!scripts/**
