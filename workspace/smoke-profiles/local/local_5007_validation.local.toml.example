# Copy to local_5007_validation.local.toml (gitignored) and replace placeholders.
#   cp workspace/smoke-profiles/local/local_5007_validation.local.toml.example \
#      workspace/smoke-profiles/local/local_5007_validation.local.toml
#
# Run dev RCx validation harness:
#   OPENFDD_VALIDATION_PROFILE=workspace/smoke-profiles/local/local_5007_validation.local.toml \
#     ./scripts/openfdd_dev_5007_report_validation.sh
#
# Or invoke the Rust binary directly:
#   cargo run -p open_fdd_edge_prototype --bin openfdd_dev_validation -- \
#     --base-url http://127.0.0.1:8080 \
#     --profile workspace/smoke-profiles/local/local_5007_validation.local.toml \
#     --duration-minutes 60 \
#     --bacnet-interval-seconds 60 \
#     --driver-interval-seconds 300 \
#     --report

profile_id = "local_5007_validation"
site_id = "site:local"
equipment_id = "equip:local-test-equipment"
duration_minutes = 60
duration_hours = 1
confirmation_minutes = 5
source_id = "source:validation-bacnet"
source_type = "bacnet"
fdd_rule_id = "oa_temp_out_of_range"
historian_subdir = "validation"
artifact_dir = "live_fdd_validation"

[dev]
report_title = "Local RCx Validation Report"

[bacnet]
enabled = true
device_instance = 0 # replace with your local BACnet test device instance
poll_interval_seconds = 60
# Format: "Display Name|<object-instance>|<fdd_input>|<object-type>|<writable>|prio:val,..."
# point.oa_t = "Outside Air Temp|<instance>|oa_t|analog-input|false"
# point.oa_h = "Outside Air Humidity|<instance>|oa_h|analog-input|false"
# point.duct_t = "Discharge Air Temp|<instance>|duct_t|analog-input|false"
# point.actuator = "Demo AO|<instance>|actuator_demo|analog-output|true|8:55.0"

[modbus]
enabled = false
host = "<replace-with-modbus-host>"
port = 1502
unit_id = 1
poll_interval_seconds = 300
# register.30001 = "temp_f_x10|input_register|0.1|temp_f"
# register.30002 = "temp_c_x10|input_register|0.1|temp_c"
# register.30003 = "humidity_x10|input_register|0.1|humidity"
# register.40001 = "temp_f_x10|holding_register|0.1|temp_f"

[haystack]
enabled = false
base_url = "http://<replace-with-niagara-host>/haystack"
username = "<replace-with-username>"
password = "<replace-with-password>"
source_id = "source:local-haystack"
poll_interval_seconds = 300
# point.oa_t = "point:oa-t|oa_t"

[parity]
temp_tolerance_f = 1.0
humidity_tolerance_pct = 5.0
timestamp_skew_seconds = 120

[json_api]
enabled = false
url = "https://httpbin.org/get"
poll_interval_seconds = 300

[csv_append]
enabled = true
source_id = "source:validation-csv"
interval_seconds = 300
