# Example auth env — DO NOT put real secrets here (this file is tracked in git).
#
# Generate bcrypt auth (no cargo required on host):
#   ./scripts/openfdd_auth_init.sh --show-secrets
#
# Rotate after GHCR image update:
#   ./scripts/openfdd_auth_init.sh --rotate --all --show-secrets
#   docker compose -f docker-compose.local.yml up -d --force-recreate openfdd-bridge
#
# With Rust installed:
#   cd edge && cargo run --release --bin openfdd_edge -- auth init --path ../workspace/auth.env.local --show-secrets

OFDD_AUTH_REQUIRED=true
OFDD_AUTH_SECRET=replace-me-with-openssl-rand-hex-32
OFDD_OPERATOR_USER=operator
OFDD_OPERATOR_PASSWORD_HASH=$2b$12$replace.with.bcrypt.hash
OFDD_INTEGRATOR_USER=integrator
OFDD_INTEGRATOR_PASSWORD_HASH=$2b$12$replace.with.bcrypt.hash
OFDD_AGENT_USER=agent
OFDD_AGENT_PASSWORD_HASH=$2b$12$replace.with.bcrypt.hash
OFDD_ADMIN_USER=admin
OFDD_ADMIN_PASSWORD_HASH=$2b$12$replace.with.bcrypt.hash
