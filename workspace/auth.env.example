# Copy to workspace/auth.env.local (gitignored) for local LAN testing.
# Behind-firewall OT model — not for public internet.
#
# DO NOT use these example values on a LAN, in production, or with BACnet writes.
# Generate fresh secrets:
#   python workspace/scripts/generate_auth_env.py
#
# Prefer password hashes in production (plaintext is dev-friendly only):
#   python workspace/scripts/hash_password.py 'your-password'
#   OFDD_OPERATOR_PASSWORD_HASH=$2b$...

OFDD_AUTH_SECRET=local-dev-secret-min-32-characters-long
OFDD_OPERATOR_USER=operator
OFDD_OPERATOR_PASSWORD=operator-local
OFDD_INTEGRATOR_USER=integrator
OFDD_INTEGRATOR_PASSWORD=msi-local
OFDD_AGENT_USER=agent
OFDD_AGENT_PASSWORD=agent-local

# Recommended bearer token lifetime for OT dashboards (8 hours default if unset)
# OFDD_AUTH_TTL_SEC=28800

# Optional: commission agent token (edge BACnet HTTP on 127.0.0.1:8767)
# OPENFDD_BACNET_COMMISSION_TOKEN=commission-local-token
