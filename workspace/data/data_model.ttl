@prefix brick: <https://brickschema.org/schema/Brick#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ofdd: <http://openfdd.local/ontology#> .
@prefix : <http://openfdd.local/site#> .

:site_s1 a brick:Site ;
  rdfs:label "BensOffice" .

:eq_bench_1 a brick:Laboratory_Equipment ;
  rdfs:label "HVAC sensor test bench" ;
  brick:isPartOf :site_s1 .

:eq_duct_1 a brick:Air_Duct ;
  rdfs:label "Supply duct section" ;
  brick:isPartOf :site_s1 .

:eq_bacnet_5007 a brick:BACnet_Device ;
  rdfs:label "BACnet device 5007" ;
  brick:isPartOf :site_s1 .

:pt_p1 a brick:Supply_Air_Temperature_Sensor ;
  rdfs:label "SAT" ;
  brick:isPointOf :eq_bench_1 ;
  ofdd:mapsToRuleInput "SAT" .

:pt__5007_analog_input_1168 a brick:Humidity_Sensor ;
  rdfs:label "oa-h" ;
  brick:isPointOf :eq_bench_1 ;
  ofdd:mapsToRuleInput "oa-h" ;
  ofdd:bacnetDeviceId "5007" ;
  ofdd:bacnetObjectIdentifier "analog-input,1168" .

:pt__5007_analog_input_1173 a brick:Zone_Air_Temperature_Sensor ;
  rdfs:label "oa-t" ;
  brick:isPointOf :eq_bench_1 ;
  ofdd:mapsToRuleInput "oa-t" ;
  ofdd:bacnetDeviceId "5007" ;
  ofdd:bacnetObjectIdentifier "analog-input,1173" .

:pt__5007_analog_input_1192 a brick:Discharge_Air_Temperature_Sensor ;
  rdfs:label "duct-t" ;
  brick:isPointOf :eq_duct_1 ;
  ofdd:mapsToRuleInput "duct-t" ;
  ofdd:bacnetDeviceId "5007" ;
  ofdd:bacnetObjectIdentifier "analog-input,1192" .

:pt__5007_analog_input_10014 a brick:Zone_Air_Temperature_Sensor ;
  rdfs:label "stat_zn-t" ;
  brick:isPointOf :eq_bench_1 ;
  ofdd:mapsToRuleInput "stat_zn-t" ;
  ofdd:bacnetDeviceId "5007" ;
  ofdd:bacnetObjectIdentifier "analog-input,10014" .
