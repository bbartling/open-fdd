# Copy to workspace/json_api.env.local (gitignored).
# Used by the JSON API driver for ${ENV:VAR} substitution in URLs and headers.
#
# OpenWeatherMap showcase (JSON API tab → "Register OpenWeather bundle"):
OPENWEATHER_API_KEY=your-api-key-here
OPENWEATHER_CITY=Madison,WI,US
# imperial = °F, metric = °C, standard = Kelvin
OPENWEATHER_UNITS=imperial
