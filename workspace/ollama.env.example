# Copy to workspace/ollama.env.local or run ./scripts/bootstrap_ollama.sh
# RAM tiers (qwen3): 8gb=qwen3:1.7b | 16gb=qwen3:4b | 32gb=qwen3:8b | 64gb=qwen3:14b
# Dev test bench (bensserver): OFDD_OLLAMA_MODEL=tinyllama + OFDD_AGENT_CHAT_WITHOUT_GPU=1
# 4GB Raspberry Pi: OFDD_OLLAMA_MODEL=qwen3:0.6b
# GPU modes: cpu | auto | gpu
# OFDD_OLLAMA_THINK: unset | true | false | low | medium | high (gpt-oss only uses levels)
OFDD_AI_BACKEND=auto
OFDD_OLLAMA_RAM_TIER=8gb
OFDD_OLLAMA_GPU_MODE=cpu
OFDD_OLLAMA_NUM_GPU=0
# Production-ish default; dev bench uses tinyllama (see compose.dev.yml).
OFDD_OLLAMA_MODEL=qwen3:1.7b
OFDD_OLLAMA_BASE_URL=http://127.0.0.1:11434
# Ollama has no built-in auth. Keep OLLAMA_HOST=127.0.0.1:11434 — never expose :11434 on the OT LAN.
# Validation: ss -tulpn | grep 11434  → 127.0.0.1 only; curl from another host must fail.
# Slow CPU runs (especially qwen3 + Thinking on): raise bridge timeout (seconds)
# OFDD_OLLAMA_TIMEOUT_S=600
