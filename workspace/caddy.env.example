# Copy to workspace/caddy.env.local — loaded by run_local.sh and Ansible edge deploy.
# Default: Caddy on :80 → bridge on 127.0.0.1:8765 (production React from workspace/api/static/app).
#
# Local stack: ./scripts/run_local.sh restart  (prod UI build + Caddy + bridge)
# UI flags: --ui-prod (default), --ui-test (vitest+build), --ui-skip, --dev (Vite :5173 optional)
#
# Modes:
#   http — plain HTTP on port 80 (default for OT LAN behind firewall)
#   tls  — self-signed HTTPS on :443, :80 redirects (run setup_caddy_certs.sh first)
#   off  — no Caddy; bridge listens on 0.0.0.0:8765 directly
#
# Local dev: if :80 bind fails, run_local.sh auto-falls back to :8080.
# Edge Ansible: Caddy package binds :80/:443 (setcap via systemd).
# One-time on dev host for real :80: sudo setcap 'cap_net_bind_service=+ep' $(which caddy)
#
OFDD_CADDY_ENABLED=1
OFDD_CADDY_MODE=http
OFDD_CADDY_TLS_CN=openfdd.local
