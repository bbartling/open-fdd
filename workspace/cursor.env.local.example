# Cursor SDK relay for in-app Agent assist (copy to workspace/cursor.env.local).
# API key: https://cursor.com/settings

CURSOR_API_KEY=
OFDD_CURSOR_AGENT_MODEL=composer-2.5

# WSL / native dev (relay on host):
OFDD_CURSOR_CHAT_URL=http://127.0.0.1:8787
OFDD_CURSOR_CHAT_PORT=8787

# Docker compose (--profile cursor with bridge):
OFDD_CURSOR_CHAT_URL=http://openfdd-cursor-relay:8787
