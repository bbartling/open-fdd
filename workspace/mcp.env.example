# Copy to workspace/mcp.env.local — loaded by run_local.sh (bridge + MCP sidecar).
OFDD_MCP_ENABLED=1
OFDD_MCP_REST_BASE=http://127.0.0.1:8090
OFDD_MCP_LISTEN_HOST=127.0.0.1
OFDD_MCP_LISTEN_PORT=8090
OFDD_MCP_RAG_INDEX_PATH=workspace/data/mcp/rag_index.json
