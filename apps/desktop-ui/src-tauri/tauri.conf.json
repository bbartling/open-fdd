{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open-FDD Desktop",
  "version": "0.1.0",
  "identifier": "io.openfdd.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Open-FDD Desktop",
        "width": 1600,
        "height": 980,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
