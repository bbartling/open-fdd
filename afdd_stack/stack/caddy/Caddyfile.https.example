# Example: HTTPS on :443 with automatic certs (replace with your public hostname).
# Copy to Caddyfile or include from the main file after you have DNS + ports 80/443.
# See docs/security.md — Phase 2 (issue #73).
#
# On the API service set: OFDD_TRUST_FORWARDED_PROTO=true so refresh cookies use Secure.

your.openfdd.example.com {
	tls {
		# Let's Encrypt by default when using a real public name.
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
	}

	handle /ai* {
		reverse_proxy api:8000
	}
	handle /api* {
		uri strip_prefix /api
		reverse_proxy api:8000
	}
	handle /auth* {
		reverse_proxy api:8000
	}
	handle /ws* {
		reverse_proxy api:8000
	}
	handle /* {
		reverse_proxy frontend:5173
	}
}
